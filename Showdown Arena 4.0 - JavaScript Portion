function getFighterHeight(characterTypeKey) {
  if (characterTypeKey === 'armoredKnight') return 91;
  if (characterTypeKey === 'combatInfantry' || characterTypeKey === 'grimReaper') return 82;
  return 74;
}

function getFighterScale(characterTypeKey) {
  if (characterTypeKey === 'armoredKnight') return 1.227;
  if (characterTypeKey === 'combatInfantry' || characterTypeKey === 'grimReaper') return 1.1;
  return 1;
}

function getPartHealthConfig(characterTypeKey) {
  if (characterTypeKey === 'armoredKnight') {
    return {
      head: 35,
      torso: 70,
      limbs: 45,
    };
  }

  if (characterTypeKey === 'deadlySniper' || characterTypeKey === 'grimReaper') {
    return {
      head: 15,
      torso: 30,
      limbs: 20,
    };
  }

  if (characterTypeKey === 'magicalSorcerer') {
    return {
      head: 10,
      torso: 20,
      limbs: 15,
    };
  }

  if (characterTypeKey === 'stealthyBandit' || characterTypeKey === 'lethalHunter') {
    return {
      head: 20,
      torso: 40,
      limbs: 25,
    };
  }

  return {
    head: 25,
    torso: 50,
    limbs: 35,
  };
}

function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

function formatHealth(value) {
  return Number.isInteger(value) ? `${value}` : value.toFixed(1);
}

function randomBetween(min, max) {
  return Math.random() * (max - min) + min;
}

function generatePlatforms() {
  const nextPlatforms = [];
  const targetCount = 3;
  let attempts = 0;

  while (nextPlatforms.length < targetCount && attempts < 120) {
    attempts += 1;
    const width = Math.round(randomBetween(135, 205));
    const height = 16;
    const x = Math.round(randomBetween(80, GAME_WIDTH - width - 80));
    const y = Math.round(randomBetween(groundY - 185, groundY - 70));
    const candidate = { x, y, width, height };
    const overlaps = nextPlatforms.some((platform) => {
      const horizontalGap = 55;
      const verticalGap = 34;
      return (
        candidate.x < platform.x + platform.width + horizontalGap &&
        candidate.x + candidate.width + horizontalGap > platform.x &&
        candidate.y < platform.y + platform.height + verticalGap &&
        candidate.y + candidate.height + verticalGap > platform.y
      );
    });

    if (!overlaps) {
      nextPlatforms.push(candidate);
    }
  }

  while (nextPlatforms.length < targetCount) {
    const fallbackIndex = nextPlatforms.length;
    nextPlatforms.push({
      x: 150 + fallbackIndex * 240,
      y: groundY - 80 - fallbackIndex * 45,
      width: 150,
      height: 16,
    });
  }

  platforms = nextPlatforms;
}

