const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const player1HealthEl = document.getElementById('player1Health');
const player2HealthEl = document.getElementById('player2Health');
const restartButton = document.getElementById('restartButton');

const GAME_WIDTH = canvas.width;
const GAME_HEIGHT = canvas.height;

const gravity = 0.6;
const friction = 0.82;
const groundY = GAME_HEIGHT - 80;

const keys = {
  ArrowLeft: false,
  ArrowRight: false,
  ArrowUp: false,
  ArrowDown: false,
  KeyA: false,
  KeyD: false,
  KeyW: false,
  KeyS: false,
};

const stage = {
  x: 0,
  y: groundY,
  width: GAME_WIDTH,
  height: 80,
};

const hitEffects = [];

class Fighter {
  constructor(x, y, color, controls) {
    this.startX = x;
    this.startY = y;
    this.x = x;
    this.y = y;
    this.width = 40;
    this.height = 60;
    this.color = color;
    this.velocity = { x: 0, y: 0 };
    this.health = 100;
    this.attackCooldown = 0;
    this.attackTimer = 0;
    this.hasHit = false;
    this.jumpHeld = false;
    this.jumpApexY = null;
    this.hasStartedJumpDescend = false;
    this.controls = controls;
    this.facing = 1;
    this.attackDuration = 30;
  }

  reset() {
    this.x = this.startX;
    this.y = this.startY;
    this.velocity = { x: 0, y: 0 };
    this.health = 100;
    this.attackCooldown = 0;
    this.attackTimer = 0;
    this.hasHit = false;
    this.jumpHeld = false;
    this.jumpApexY = null;
    this.hasStartedJumpDescend = false;
  }

  get hitbox() {
    return {
      x: this.x,
      y: this.y,
      width: this.width,
      height: this.height,
    };
  }

  get attackBox() {
    if (this.attackTimer > 0) {
      return {
        x: this.x + (this.facing > 0 ? this.width : -70),
        y: this.y + 16,
        width: 70,
        height: 18,
      };
    }
    return null;
  }

  draw() {
    ctx.fillStyle = this.color;
    ctx.fillRect(this.x, this.y, this.width, this.height);
    ctx.fillStyle = '#fff';
    ctx.fillRect(this.x + 8, this.y + 12, 6, 6);
    ctx.fillRect(this.x + this.width - 14, this.y + 12, 6, 6);

    const swordOriginX = this.x + (this.facing > 0 ? this.width : 0);
    const swordOriginY = this.y + 34;

    ctx.save();
    ctx.translate(swordOriginX, swordOriginY);

    if (this.attackTimer > 0) {
      const progress = 1 - this.attackTimer / this.attackDuration;
      const swing = Math.PI * 35 / 180; // 35 degrees in radians
      const startAngle = this.facing > 0 ? -swing : Math.PI - swing;
      const endAngle = this.facing > 0 ? swing : Math.PI + swing;
      const angle = startAngle + (endAngle - startAngle) * progress;
      ctx.rotate(angle);
    } else {
      const swing = Math.PI * 35 / 180;
      ctx.rotate(this.facing > 0 ? -swing : Math.PI + swing);
    }

    ctx.fillStyle = '#ddd';
    ctx.fillRect(0, -3, 70, 6);
    ctx.fillStyle = '#888';
    ctx.fillRect(-6, -5, 12, 10);
    ctx.fillStyle = '#6b4a2d';
    ctx.fillRect(-8, -2, 8, 4);
    ctx.restore();

    if (this.attackBox) {
      ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
      const box = this.attackBox;
      ctx.fillRect(box.x, box.y, box.width, box.height);
    }
  }

  update() {
    const controls = this.controls;
    if (keys[controls.left]) {
      this.velocity.x = Math.max(this.velocity.x - 0.5, -3.5);
      this.facing = -1;
    } else if (keys[controls.right]) {
      this.velocity.x = Math.min(this.velocity.x + 0.5, 3.5);
      this.facing = 1;
    } else {
      this.velocity.x *= friction;
    }

    if (keys[controls.jump] && this.onGround() && !this.jumpHeld) {
      this.velocity.y = -18;
      this.jumpHeld = true;
      this.jumpApexY = this.y;
      this.hasStartedJumpDescend = false;
    }

    if (!keys[controls.jump]) {
      this.jumpHeld = false;
    }

    if (this.jumpApexY !== null) {
      if (this.velocity.y < 0) {
        this.jumpApexY = Math.min(this.jumpApexY, this.y);
      } else if (this.velocity.y >= 0 && !this.onGround()) {
        this.hasStartedJumpDescend = true;
      }
    }

    if (keys[controls.attack] && this.attackCooldown <= 0) {
      this.attackTimer = this.attackDuration;
      this.attackCooldown = 42;
      this.hasHit = false;
    }

    this.velocity.y += gravity;
    this.x += this.velocity.x;
    this.y += this.velocity.y;

    if (this.x < 0) this.x = 0;
    if (this.x + this.width > GAME_WIDTH) this.x = GAME_WIDTH - this.width;
    if (this.y + this.height >= groundY) {
      this.y = groundY - this.height;
      this.velocity.y = 0;
      this.jumpApexY = null;
      this.hasStartedJumpDescend = false;
    }

    if (this.attackTimer > 0) {
      this.attackTimer -= 1;
    }

    if (this.attackCooldown > 0) {
      this.attackCooldown -= 1;
    }
  }

  onGround() {
    return this.y + this.height >= groundY - 0.5;
  }

  isCriticalHit() {
    if (this.jumpApexY === null || !this.hasStartedJumpDescend || this.onGround()) {
      return false;
    }
    const fallMidpoint = this.jumpApexY + (groundY - this.jumpApexY) / 2;
    return this.y > fallMidpoint;
  }
}

const player1 = new Fighter(120, groundY - 60, '#4ea6ff', {
  left: 'KeyA',
  right: 'KeyD',
  jump: 'KeyW',
  attack: 'KeyS',
});

const player2 = new Fighter(760, groundY - 60, '#ff906d', {
  left: 'ArrowLeft',
  right: 'ArrowRight',
  jump: 'ArrowUp',
  attack: 'ArrowDown',
});

function rectIntersect(a, b) {
  return (
    a.x < b.x + b.width &&
    a.x + a.width > b.x &&
    a.y < b.y + b.height &&
    a.y + a.height > b.y
  );
}

function updateGame() {
  player1.update();
  player2.update();
  detectAttacks();
  updateHealthUI();
}

function detectAttacks() {
  const p1Attack = player1.attackBox;
  const p2Attack = player2.attackBox;
  if (
    p1Attack &&
    rectIntersect(p1Attack, player2.hitbox) &&
    player1.attackTimer > 6 &&
    !player1.hasHit
  ) {
    const isCrit = player1.isCriticalHit();
    const damage = isCrit ? 10 : 5;
    player2.health = Math.max(player2.health - damage, 0);
    player2.velocity.x = (isCrit ? 16 : 12) * player1.facing;
    player2.velocity.y = isCrit ? -12 : -10;
    player1.hasHit = true;
    hitEffects.push({ x: player2.x + player2.width / 2, y: player2.y + player2.height / 2, timer: isCrit ? 30 : 18, color: isCrit ? 'gold' : 'white' });
  }

  if (
    p2Attack &&
    rectIntersect(p2Attack, player1.hitbox) &&
    player2.attackTimer > 6 &&
    !player2.hasHit
  ) {
    const isCrit = player2.isCriticalHit();
    const damage = isCrit ? 10 : 5;
    player1.health = Math.max(player1.health - damage, 0);
    player1.velocity.x = (isCrit ? 16 : 12) * player2.facing;
    player1.velocity.y = isCrit ? -12 : -10;
    player2.hasHit = true;
    hitEffects.push({ x: player1.x + player1.width / 2, y: player1.y + player1.height / 2, timer: isCrit ? 30 : 18, color: isCrit ? 'gold' : 'white' });
  }
}

function updateHealthUI() {
  player1HealthEl.textContent = `Player 1 Health: ${player1.health}`;
  player2HealthEl.textContent = `Player 2 Health: ${player2.health}`;
}

function drawStage() {
  ctx.fillStyle = '#18222d';
  ctx.fillRect(0, 0, GAME_WIDTH, GAME_HEIGHT);
  ctx.fillStyle = '#2a394a';
  ctx.fillRect(stage.x, stage.y, stage.width, stage.height);
}

function draw() {
  drawStage();
  player1.draw();
  player2.draw();

  // draw hit effects
  for (let i = hitEffects.length - 1; i >= 0; i--) {
    const e = hitEffects[i];
    const base = 30;
    const alpha = Math.max(0, e.timer / base);
    ctx.globalAlpha = alpha;
    ctx.fillStyle = e.color;
    ctx.beginPath();
    ctx.arc(e.x, e.y, (base - e.timer) * 0.7 + 4, 0, Math.PI * 2);
    ctx.fill();
    ctx.globalAlpha = 1;
    e.timer -= 1;
    if (e.timer <= 0) hitEffects.splice(i, 1);
  }

  if (player1.health <= 0 || player2.health <= 0) {
    ctx.fillStyle = 'rgba(0, 0, 0, 0.62)';
    ctx.fillRect(0, 0, GAME_WIDTH, GAME_HEIGHT);
    ctx.fillStyle = '#fff';
    ctx.font = '46px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(
      player1.health <= 0 ? 'Player 2 Wins!' : 'Player 1 Wins!',
      GAME_WIDTH / 2,
      GAME_HEIGHT / 2
    );
    ctx.font = '18px Inter, sans-serif';
    ctx.fillText('Press Restart to play again', GAME_WIDTH / 2, GAME_HEIGHT / 2 + 40);
  }
}

function loop() {
  updateGame();
  draw();
  requestAnimationFrame(loop);
}

window.addEventListener('keydown', (event) => {
  if (keys.hasOwnProperty(event.code)) {
    keys[event.code] = true;
    event.preventDefault();
  }
});

window.addEventListener('keyup', (event) => {
  if (keys.hasOwnProperty(event.code)) {
    keys[event.code] = false;
    event.preventDefault();
  }
});

restartButton.addEventListener('click', () => {
  player1.reset();
  player2.reset();
  updateHealthUI();
});

updateHealthUI();
requestAnimationFrame(loop);
